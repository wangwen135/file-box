# Compiled class files
*.class

# Logs
*.log
/logs/
*.log.*

# Build outputs
/target/
/build/
/out/

# Maven
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties

# IDEs
/.idea/
/*.iml
*.iws
.classpath
.project
.settings/

# VS Code
.vscode/

# OS files
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
/.multipart-tmp/
/runtime/
*.swp
*~

# Runtime storage (用户上传的实际文件,不应入库 / actual uploaded files, not VCS)
/uploads/
/test-uploads/
/data/

# Local Spring override. Business config config/filebox.yml is tracked for dev sync.
config/application.yml
config/*.bak
config/*.tmp

# Archives and packages
*.jar
*.war
*.ear
*.zip

# Secrets / keys
*.jks
*.keystore
.env

# IntelliJ specific (keep workspace files out of VCS)
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/shelf/
.idea/**/dictionaries/

# Ignore node modules if present
node_modules/

# Ignore generated sources (if any)
target/
# AI dev script (local only)
dev-restart.sh
